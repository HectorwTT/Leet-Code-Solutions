class Solution {
public:
    int minimumIndex(vector<int>& capacity, int itemSize) {
      unordered_map<int,int> map;
      int min=101;
      for(int i=0;i<capacity.size();i++){
       if(capacity[i]>=itemSize){
        min=std::min(min,capacity[i]);
        if(map.find(capacity[i])==map.end())map[capacity[i]]=i;
       } 
      }  
      if(min==101)return -1;
      else return map[min];    
    }
};
