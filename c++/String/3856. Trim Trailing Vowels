class Solution {
public:
    string trimTrailingVowels(string s) {
      int last=s.size()-1;
      for(int i=last;i>=0;i--){
       char ch=s[i];
       if(ch!='a' && ch!='e' && ch!='i' && ch!='o' && ch!='u'){
        last=i;
        break;
       }else last=i-1; 
      }
      if(last==-1) return "";
      else return s.substr(0,last+1);  
    }
};
