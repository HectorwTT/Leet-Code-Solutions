var trimTrailingVowels = function(s) {
      let last=s.length-1;
      for(let i=last;i>=0;i--){
       var ch=s.charAt(i);
       if(ch!='a' && ch!='e' && ch!='i' && ch!='o' && ch!='u'){
        last=i;
        break;
       }else last=i-1; 
      }
      if(last==-1) return "";
      else return s.substring(0,last+1);    
};
