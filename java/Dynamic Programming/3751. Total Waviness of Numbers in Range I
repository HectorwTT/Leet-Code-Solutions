class Solution {
    public int totalWaviness(int num1, int num2) {
      int answer=0;
      for(int i=num1;i<=num2;i++){
       String number=""+i;
       if(number.length()<3)continue;
       for(int j=1;j<number.length()-1;j++){
        char curr=number.charAt(j);
        char prev=number.charAt(j-1);
        char next=number.charAt(j+1);
        if(curr>prev && curr>next)answer++;
        else if(curr<prev && curr<next)answer++;
       } 
      }
      return answer;  
    }
}
