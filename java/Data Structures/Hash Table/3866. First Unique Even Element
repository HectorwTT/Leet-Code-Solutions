class Solution {
    public int firstUniqueEven(int[] nums) {
      HashMap<Integer,Integer> map=new HashMap<>();
      HashMap<Integer,Integer> map1=new HashMap<>();
      int minIndex=nums.length;
      for(int i=0;i<nums.length;i++){
       if(nums[i]%2==1) continue; 
       if(!map.containsKey(nums[i]))map.put(nums[i],1); 
       else map.replace(nums[i],map.get(nums[i])+1);
       if(!map1.containsKey(nums[i]))map1.put(nums[i],i); 
      }
      for(Integer key:map.keySet()){
       if(map.get(key)==1){
        minIndex=Math.min(map1.get(key),minIndex);
       } 
      }
      if(minIndex==nums.length)return -1;
      else return nums[minIndex];
    }
}
