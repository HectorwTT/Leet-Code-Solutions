class Solution {
    public int minAbsoluteDifference(int[] nums) {
      int answer=101;
      HashMap<Integer,Integer> lastIndexesMap=new HashMap<>();
      HashMap<Integer,Integer> nextIndexesMap=new HashMap<>();
      for(int i=0;i<nums.length;i++){
       if(nums[i]==1){
        if(lastIndexesMap.containsKey(2)) answer=Math.min(answer,i-lastIndexesMap.get(2)); 
        lastIndexesMap.put(1,i); 
       }else if(nums[i]==2){
        if(lastIndexesMap.containsKey(1)) answer=Math.min(answer,i-lastIndexesMap.get(1)); 
        lastIndexesMap.put(2,i); 
       } 
      } 

     for(int i=nums.length-1;i>=0;i--){
       if(nums[i]==1){
        if(nextIndexesMap.containsKey(2)) answer=Math.min(answer,nextIndexesMap.get(2)-i); 
        nextIndexesMap.put(1,i); 
       }else if(nums[i]==2){
        if(nextIndexesMap.containsKey(1)) answer=Math.min(answer,nextIndexesMap.get(1)-i); 
        nextIndexesMap.put(2,i); 
       } 
      }
      if(answer==101) return -1;
      else return answer; 
    }
}
