class Solution {
    public int[] concatWithReverse(int[] nums) {
     int [] answer= new int[nums.length*2];
     int index=0;
     Stack<Integer> stack=new Stack<>();
     for(int i=0;i<nums.length;i++){
      answer[index++]=nums[i];
      stack.push(nums[i]);  
     }
     while(!stack.isEmpty()){
      answer[index++] =stack.pop(); 
     } 
     return answer;          
    }
}
