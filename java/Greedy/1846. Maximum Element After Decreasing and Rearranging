class Solution {
    public int maximumElementAfterDecrementingAndRearranging(int[] arr) {
      int answer=1;
      Arrays.sort(arr);
      arr[0]=1;
      for(int i=1;i<arr.length;i++){
        if(arr[i]-arr[i-1]>1)arr[i]=arr[i-1]+1;
        answer=Math.max(answer,arr[i]);
      } 
      return answer; 
    }
}
