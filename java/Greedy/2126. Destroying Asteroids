class Solution {
    public boolean asteroidsDestroyed(int mass, int[] asteroids) {
      Arrays.sort(asteroids);
      long mass1=1L*mass;
      for(int i=0;i<asteroids.length;i++){
       long massOfAsteroid=1L*asteroids[i]; 
       if(mass1<massOfAsteroid) return false;
       else mass1+=massOfAsteroid;
      }
      return true;  
    }
}
