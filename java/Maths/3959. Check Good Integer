class Solution {
    public boolean checkGoodInteger(int n) {
     int digitSum=0;
     int squareSum=0;
     String number=""+n;
     for(int i=0;i<number.length();i++){
      char digit=number.charAt(i);
      digitSum+=(digit-48); 
      int digitSquared=(int)Math.pow((digit-48),2);  
      squareSum+=digitSquared;
     } 
     return (squareSum-digitSum)>=50;  
    }
}
