public class Solution {
    public int MinAbsoluteDifference(int[] nums) {
      int answer=101;
      Dictionary<int,int> lastIndexesMap=new Dictionary<int,int>();
      Dictionary<int,int> nextIndexesMap=new Dictionary<int,int>();
      for(int i=0;i<nums.Length;i++){
       if(nums[i]==1){
        if(lastIndexesMap.ContainsKey(2)) answer=Math.Min(answer,i-lastIndexesMap[2]); 
        lastIndexesMap[1]=i; 
       }else if(nums[i]==2){
        if(lastIndexesMap.ContainsKey(1)) answer=Math.Min(answer,i-lastIndexesMap[1]); 
        lastIndexesMap[2]=i; 
       } 
      } 

     for(int i=nums.Length-1;i>=0;i--){
       if(nums[i]==1){
        if(nextIndexesMap.ContainsKey(2)) answer=Math.Min(answer,nextIndexesMap[2]-i); 
        nextIndexesMap[1]=i; 
       }else if(nums[i]==2){
        if(nextIndexesMap.ContainsKey(1)) answer=Math.Min(answer,nextIndexesMap[1]-i); 
        nextIndexesMap[2]=i; 
       } 
      }
      if(answer==101) return -1;
      else return answer;    
    }
}
