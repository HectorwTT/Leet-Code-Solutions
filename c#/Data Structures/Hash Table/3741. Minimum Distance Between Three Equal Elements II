public class Solution {
    public int MinimumDistance(int[] nums) {
     int []  lastIndexes=new int[nums.Length];
     int [] nextIndexes=new int[nums.Length];
     Dictionary<int,int> lastIndexesMap=new Dictionary<int,int>();
     Dictionary<int,int> nextIndexesMap=new Dictionary<int,int>();   
     int answer=3*(int)Math.Pow(10,5); 
     Array.Fill(lastIndexes,-1);
     Array.Fill(nextIndexes,-1);
     for(int i=0;i<nums.Length;i++){
      if(!lastIndexesMap.ContainsKey(nums[i]))lastIndexesMap[nums[i]]=i; 
      else{
        lastIndexes[i]=lastIndexesMap[nums[i]];
        lastIndexesMap[nums[i]]=i;
      }
     }  
     for(int i=nums.Length-1;i>=0;i--){
      if(!nextIndexesMap.ContainsKey(nums[i]))nextIndexesMap[nums[i]]=i; 
      else{
        nextIndexes[i]=nextIndexesMap[nums[i]];
        nextIndexesMap[nums[i]]=i;
      }
     }
     for(int i=0;i<nums.Length;i++){
      if(lastIndexes[i]==-1 || nextIndexes[i]==-1) continue;
      answer=Math.Min(answer,Math.Abs(lastIndexes[i]-i)+Math.Abs(lastIndexes[i]-nextIndexes[i])
                      +Math.Abs(nextIndexes[i]-i)); 
     }
     if(answer==3*(int)Math.Pow(10,5))return -1;
     else return answer;   
    }
}
